;; This is a dummy package which fetches the modules Discord needs.
;; Each module has a source which is a Brotli compressed tar file.
;; Decompress each of those files, then recompress them as zip files which is
;; what the client expects.
(define discord-modules
  (package
    (name "discord-modules")
    (version discord-version)
    (source
     (file-union
      "modules"
      (map (lambda (name uri hash)
             (list
              (string-append name ".br")
              (origin (method url-fetch) (uri uri) (sha256 (base32 hash)))))
           module-names module-uris module-hashes)))
    (build-system (@ (guix build-system copy) copy-build-system))
    (arguments
     (list
      #:install-plan
      #~(map (lambda (name)
               (let ((f (string-append name ".zip"))) (list f f)))
             '#$module-names)
      #:phases
      (with-imported-modules '((guix build utils))
        #~(modify-phases %standard-phases
            (add-after 'unpack 'brotli-repack-to-zip
              (lambda* (#:key #:allow-other-keys)
                (use-modules (guix build utils))
                (for-each
                 (lambda (name)
                   (invoke
                    "sh" "-c"
                    (string-append
                     "brotli --decompress --stdout " name ".br"
                     " | tar x"
                     "; cd files"
                     "; 7z a ../" name ".zip *"
                     "; cd .."
                     "; rm -rf files")))
                 '#$module-names)))))))
    (native-inputs (list brotli tar 7zip))
